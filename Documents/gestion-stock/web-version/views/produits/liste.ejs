<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Liste des produits</h1>
    <a href="/produits/ajouter" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Ajouter
    </a>
</div>

<!-- Filtre par catégorie -->
<div class="row mb-3">
    <div class="col-md-6">
        <form class="d-flex" method="GET" action="/produits">
            <select name="categorie" class="form-select me-2">
                <option value="toutes">Toutes les catégories</option>
                <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>" <%= categorieFiltre === cat.id ? 'selected' : '' %>><%= cat.nom %></option>
                <% }) %>
            </select>
            <button type="submit" class="btn btn-outline-secondary">Filtrer</button>
        </form>
    </div>
</div>

<!-- Liste des produits -->
<div class="row">
    <% if (produits && produits.length > 0) { %>
        <% produits.forEach(produit => { %>
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title"><%= produit.nom %></h5>
                    <p class="card-text text-muted"><%= produit.description || 'Aucune description' %></p>
                    <ul class="list-unstyled">
                        <li><strong>ID:</strong> <%= produit.id %></li>
                        <li><strong>Quantité:</strong> <%= produit.quantite %></li>
                        <li><strong>Prix:</strong> <%= produit.prix.toFixed(2) %> FCFA</li>
                        <li><strong>Seuil:</strong> <%= produit.seuilAlerte %></li>
                        <li>
                            <span class="badge bg-<%= produit.estEnStockInsuffisant() ? 'danger' : 'success' %>">
                                <%= produit.estEnStockInsuffisant() ? 'Stock insuffisant' : 'OK' %>
                            </span>
                        </li>
                    </ul>
                </div>
                <div class="card-footer bg-transparent">
                    <div class="btn-group w-100">
                        <a href="/produits/<%= produit.id %>/modifier" class="btn btn-warning btn-sm">
                            <i class="bi bi-pencil"></i> Modifier
                        </a>
                        <form action="/produits/<%= produit.id %>?_method=DELETE" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce produit ?')">
                                <i class="bi bi-trash"></i> Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    <% } else { %>
        <div class="col-12">
            <div class="alert alert-info">Aucun produit trouvé</div>
        </div>
    <% } %>
</div>